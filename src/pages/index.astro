---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import BlogPost from '../components/BlogPost_index.astro';
import { getCollection } from 'astro:content';

const pageTitle = "Home";
const description = "雑記スペース";

const allPostsData = await getCollection('posts');
const nonDraftPosts = allPostsData.filter((post) => !post.data.draft);
const sortedPosts = nonDraftPosts.sort((a, b) => {
    const a_Date = new Date(a.data.pubDate);
    const b_Date = new Date(b.data.pubDate);
    return b_Date.getTime() - a_Date.getTime();
}).slice(0, 5); // 最新5件

---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={"ふみ箱"} />
    <meta name="twitter:description" content={description}
    />
    <meta name="theme-color" content="#234059">
    <title>{"ふみ箱"}</title>
  </head>
  <body>
    <Header />
    
    <h1>{pageTitle}</h1>

    <div class="contents">
        <p>
            備忘録というか雑記スペースというか。ごみ箱じゃないよ。
        </p>
    </div>

    <div class="article-list">
        <h2>最近の記事</h2>
        {sortedPosts.slice(0,3).map((post) => 
        <BlogPost url={`/posts/${post.slug}`}
          title={post.data.title}
          pubDate={post.data.pubDate}
          description={post.data.description}/>)
        }
      </div>

    <Footer />
    <script>
      import "../scripts/menu.js";
    </script>
  </body>
</html>
